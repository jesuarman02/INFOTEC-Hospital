<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20260116042458-1" author="jhipster">
        <createTable tableName="historial_medico">
            <column name="id" type="bigint" autoIncrement="true" startWith="1500">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            
            <column name="datos_biometricos_sanguineos" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="alergias" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="enfermedades_cronicas" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="cirugias_previas" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="medicamentos_actuales" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="antecedentes_familiares_hereditarios" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="antecedentes_personales_patologicos" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="habitos_consumo_otros" type="${clobType}">
                <constraints nullable="true" />
            </column>
            <column name="observaciones_generales" type="${clobType}">
                <constraints nullable="true" />
            </column>
            
            </createTable>
    </changeSet>

    </databaseChangeLog>